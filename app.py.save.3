from flask import Flask, render_template, request, redirect, url_for, session, flash
from flask_sqlalchemy import SQLAlchemy
from sqlalchemy.exc import IntegrityError
from werkzeug.security import generate_password_hash, check_password_hash

app = Flask(__name__)
app.secret_key = 'university_clinic_secret_key'
app.config['SQLALCHEMY_DATABASE_URI'] = 'mysql+pymysql://root:10121@localhost/clinic_db'
db = SQLAlchemy(app)

class User(db.Model):
    __tablename__ = 'users'
    id = db.Column(db.Integer, primary_key=True)
    username = db.Column(db.String(50), unique=True, nullable=False)
    password = db.Column(db.String(255), nullable=False)
    role = db.Column(db.String(20), nullable=False)

class Student(db.Model):
    __tablename__ = 'students'
    id = db.Column(db.Integer, primary_key=True)
    sr_code = db.Column(db.String(20), unique=True, nullable=False)
    password = db.Column(db.String(255), nullable=False)

@app.route('/register', methods=['GET', 'POST'])
def register():
    # --- THIS HANDLES SUBMITTING THE FORM ---
    if request.method == 'POST':
        sr = request.form.get('sr_code', '').strip()
        pw = request.form.get('password', '')
        fname = request.form.get('fullname', '').strip().title()

        try:
            hashed_pw = generate_password_hash(pw)

            # Insert into account table
            db.session.execute(db.text(
                "INSERT INTO students (sr_code, password) VALUES (:sr, :pw)"),
                {'sr': sr, 'pw': hashed_pw})

            # Insert into medical table
            db.session.execute(db.text(
                "INSERT INTO medical_records (sr_code, fullname) VALUES (:sr, :n)"),
                {'sr': sr, 'n': fname})

            db.session.commit()
            flash("Account created! You can now log in.", "success")
            return redirect(url_for('login'))

        except IntegrityError:
            # This PREVENTS the white screen error
            db.session.rollback()
            flash("Account already exists with this SR-Code.", "error")
            return render_template('register.html')

        except Exception as e:
            db.session.rollback()
            # If any other error happens, show the message instead of crashing
            flash(f"System Error: {str(e)}", "error")
            return render_template('register.html')

    return render_template('register.html')

@app.route('/student_dashboard')
def student_dashboard():
    # Security Check: Ensure only students can access this
    if session.get('role') != 'student':
        return redirect(url_for('login'))

    sr = session.get('user_sr')
    # Fetch all columns including the new clinical tracking fields
    record = db.session.execute(db.text("SELECT * FROM medical_records WHERE sr_code=:sr"), {'sr': sr}).fetchone()

    if record:
        return render_template('student_dashboard.html',
                               name=record.fullname,
                               sr=sr,
                               year=record.year_level,
                               bday=record.birthdate,
                               addr=record.address,
                               contact=record.parent_contact,
                               blood=record.blood_type,
                               allergies=record.allergies,
                               referral=record.referral_status,
                               log=record.visit_history)

    return "<h1>Profile Error</h1>Record not found. Please contact the clinic office."
@app.route('/admin', defaults={'dept_name': None, 'program_name': None})
@app.route('/admin_dashboard', defaults={'dept_name': None, 'program_name': None})
@app.route('/admin/<dept_name>', defaults={'program_name': None})
@app.route('/admin/<dept_name>/<program_name>')
def admin_dashboard(dept_name, program_name):
    # Security: Restrict access to Admins only
    if session.get('role') != 'admin':
        return redirect(url_for('login'))

    # Mapping: Translates UI labels (COE) to Database names (Engineering)
    dept_map = {'COE': 'Engineering', 'CICS': 'CICS', 'CET': 'CET', 'CAFAD': 'CAFAD'}
    db_dept = dept_map.get(dept_name, dept_name)

    programs = []
    students = []

    try:
        # DATA LOGIC: Level 3 - Show Student Table
        if program_name:
            students = db.session.execute(
                db.text("SELECT * FROM medical_records WHERE program=:p"), 
                {'p': program_name}
            ).fetchall()

        # DATA LOGIC: Level 2 - Show Program Folders
        elif dept_name:
            res = db.session.execute(
                db.text("SELECT DISTINCT program FROM medical_records WHERE college=:c"), 
                {'c': db_dept}
            ).fetchall()
            programs = [r[0] for r in res]

        # DATA LOGIC: Level 1 - Show Department Folders (Default)
        return render_template('admin.html', 
                               dept_name=dept_name, 
                               program_name=program_name, 
                               programs=programs, 
                               students=students)
    except Exception as e:
        return f"Dashboard Error: {e}"


# FEATURE: Individual Record Management
# PURPOSE: Fetches a single student's data for the edit form
@app.route('/record/<sr_code>')
def manage_record(sr_code):
    if session.get('role') != 'admin':
        return redirect(url_for('login'))

    try:
        student = db.session.execute(
            db.text("SELECT * FROM medical_records WHERE sr_code=:sr"),
            {'sr': sr_code}
        ).fetchone()

        if student:
            return render_template('admin.html', student_detail=student)
        return "Student record not found."
    except Exception as e:
        return f"Load Error: {e}"


# FEATURE: Save Changes & Smart Redirect
# PURPOSE: Updates MySQL and returns the user to the specific student list
@app.route('/update_record/<sr_code>', methods=['POST'])
def update_record(sr_code):
    if session.get('role') != 'admin':
        return redirect(url_for('login'))

    # Get redirect info
    student_info = db.session.execute(
        db.text("SELECT college, program FROM medical_records WHERE sr_code=:sr"),
        {'sr': sr_code}
    ).fetchone()

    # Collect ALL form data including Address and Contact
    n = request.form.get('fullname')
    b = request.form.get('birthday')
    addr = request.form.get('address')
    cont = request.form.get('contact')
    bt = request.form.get('blood_type')
    a = request.form.get('allergies')
    h = request.form.get('history')

    try:
        # Update MySQL with the confirmed column names from your DESCRIBE
        db.session.execute(
            db.text("""UPDATE medical_records
                       SET fullname=:n, birthdate=:b, address=:addr,
                           parent_contact=:cont, blood_type=:bt,
                           allergies=:a, visit_history=:h
                       WHERE sr_code=:sr"""),
            {'n': n, 'b': b, 'addr': addr, 'cont': cont, 'bt': bt, 'a': a, 'h': h, 'sr': sr_code}
        )
        db.session.commit()

        # Smart Redirect
        inv_map = {'Engineering': 'COE', 'CICS': 'CICS', 'CET': 'CET', 'CAFAD': 'CAFAD'}
        ui_dept = inv_map.get(student_info.college, student_info.college)
        return redirect(url_for('admin_dashboard', dept_name=ui_dept, program_name=student_info.program))
    except Exception as e:
        return f"Update Error: {e}"

# FEATURE: Session Termination
@app.route('/logout')
def logout():
    session.clear()
    return redirect(url_for('login'))


if __name__ == '__main__':
    app.run(debug=True)
