from flask import Flask, render_template, request, redirect, url_for, session
from flask_sqlalchemy import SQLAlchemy
from werkzeug.security import generate_password_hash, check_password_hash
import os

app = Flask(__name__)
app.secret_key = 'bsu_clinic_secret_key'

# DATABASE CONFIGURATION
# Using the dedicated clinic_admin user for better security
app.config['SQLALCHEMY_DATABASE_URI'] = 'mysql+pymysql://clinic_admin:ClinicPassword123!@localhost/clinic_db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

db = SQLAlchemy(app)

# --- ROUTES ---

@app.route('/')
def index():
    return redirect(url_for('login'))


@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        role = request.form.get('role')

        # Checking different fields based on the role tab used in HTML
        if role == 'admin':
            user_val = request.form.get('admin_user')
            pass_val = request.form.get('admin_password')
            query = "SELECT password FROM admins WHERE sr_code=:u"
        else:
            user_val = request.form.get('sr_code')
            pass_val = request.form.get('password')
            query = "SELECT password FROM students WHERE sr_code=:u"

        try:
            user = db.session.execute(db.text(query), {'u': user_val}).fetchone()

            if user and check_password_hash(user[0], pass_val):
                session['user_sr'] = user_val
                session['role'] = role
                if role == 'admin':
                    return redirect(url_for('admin_dashboard'))
                return redirect(url_for('student_dashboard'))
        except Exception as e:
            return f"Login System Error: {e}"

        return "Invalid Credentials. <a href='/login'>Try again</a>"

    return render_template('login.html')

@app.route('/student_dashboard')
def student_dashboard():
    if session.get('role') != 'student':
        return redirect(url_for('login'))

    sr = session.get('user_sr')
    record = db.session.execute(db.text("SELECT * FROM medical_records WHERE sr_code=:sr"), {'sr': sr}).fetchone()

    if record:
        return f"<h1>Student Dashboard</h1>Welcome {record.fullname}! Your blood type is {record.blood_type}. <a href='/logout'>Logout</a>"
    return "Profile not found. <a href='/logout'>Logout</a>"

@app.route('/admin_dashboard')
def admin_dashboard():
    if session.get('role') != 'admin':
        return redirect(url_for('login'))
    return "<h1>Admin Dashboard</h1><p>Welcome, Administrator.</p><a href='/logout'>Logout</a>"

@app.route('/logout')
def logout():
    session.clear()
    return redirect(url_for('login'))

if __name__ == '__main__':
    app.run(debug=True)
